# 虾掌柜ERP 环境变量配置
# 复制此文件为 .env 并根据需要修改

# ── 服务端口 ──
PORT=3000

# ── 数据库路径（相对于 server 目录） ──
DB_PATH=data/erp.db

# ── 文件上传目录 ──
# 本地开发：E:/tiktok-crm/data/uploads
# Docker部署：/app/data/uploads
UPLOAD_DIR=E:/tiktok-crm/data/uploads

# ── TikTok Shop OAuth ──
# Partner Center 创建应用后获取
TIKTOK_APP_KEY=your_app_key_here
TIKTOK_APP_SECRET=your_app_secret_here
# ⚠️ 授权ID (Service ID) — 多数情况下与 APP_KEY 相同，但如果不同必须单独填写
# 获取路径: Partner Center → 应用详情 → 授权信息 → Service ID (授权ID)
TIKTOK_SERVICE_ID=
# OAuth 回调地址（必须与 Partner Center 后台登记的一致）
# 格式: https://your-domain.com/api/shops/tiktok/callback
TIKTOK_REDIRECT_URI=https://your-domain.com/api/shops/tiktok/callback
# 前端地址（授权成功后跳回）
FRONTEND_URL=http://localhost:5173
# TikTok API 环境: sandbox 或 production
TIKTOK_ENV=sandbox
# TikTok API 地址
# sandbox: https://open-api-sandbox.tiktokglobalshop.com
# production: https://open-api.tiktokglobalshop.com
TIKTOK_API_BASE=https://open-api-sandbox.tiktokglobalshop.com

# ── 订单自动同步（每 N 分钟从 TikTok API 拉取新订单） ──
AUTO_SYNC_INTERVAL_MINUTES=10
# 启动时是否立即执行一次同步（默认 true）
AUTO_SYNC_RUN_ON_START=true
