TIKTOK_APP_SECRET=0f17b939f9f7074ffbb396510110cb07effd1cf5
TIKTOK_SERVICE_ID=7644440536870733576
# OAuth 回调地址（必须与 Partner Center 后台登记的一致）
TIKTOK_REDIRECT_URI=http://8.163.24.221/api/shops/tiktok/callback
# TikTok API 环境: sandbox 或 production
